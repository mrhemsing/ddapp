generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntitlementSource {
  stripe
}

enum MagicLinkPurpose {
  activate
  signin
}

enum AdminStopStatus {
  live
  held
}

enum OrderProposalStatus {
  draft
  approved
  rejected
  published
}

model User {
  id                 String           @id @default(cuid())
  email              String           @unique
  marketingConsent   Boolean          @default(false)
  marketingConsentAt DateTime?
  createdAt          DateTime         @default(now())
  devices            Device[]
  entitlements       Entitlement[]
  magicLinks         MagicLinkToken[]
}

model Entitlement {
  id                    String            @id @default(cuid())
  userId                String
  packSlug              String
  source                EntitlementSource @default(stripe)
  stripeSessionId       String            @unique
  stripePaymentIntentId String?
  grantedAt             DateTime          @default(now())
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, packSlug])
  @@index([packSlug])
}

model Device {
  id               String   @id @default(cuid())
  userId           String
  deviceId         String
  label            String?
  sessionTokenHash String   @unique
  createdAt        DateTime @default(now())
  lastSeenAt       DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId, lastSeenAt])
}

model MagicLinkToken {
  id        String           @id @default(cuid())
  userId    String?
  email     String
  tokenHash String           @unique
  purpose   MagicLinkPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
}

model AdminStop {
  id              String          @id @default(cuid())
  slug            String          @unique
  name            String
  address         String?
  lat             Float
  lng             Float
  narrationScript String          @db.Text
  safetyWarning   String          @db.Text
  themeTags       String[]
  status          AdminStopStatus @default(held)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  tourStops       TourStop[]

  @@index([status])
}

model AdminTour {
  id                    String          @id @default(cuid())
  slug                  String          @unique
  title                 String
  targetDurationMinutes Int             @default(70)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  stops                 TourStop[]
  proposals             OrderProposal[]
}

model TourStop {
  id        String    @id @default(cuid())
  tourId    String
  stopId    String
  position  Int
  isStart   Boolean   @default(false)
  isFinale  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  stop      AdminStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  tour      AdminTour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, stopId])
  @@unique([tourId, position])
  @@index([stopId])
}

model OrderProposal {
  id                    String              @id @default(cuid())
  tourId                String
  status                OrderProposalStatus @default(draft)
  trigger               String
  currentOrder          Json
  proposedOrder         Json
  placementReasons      Json
  invalidatedLegs       Json
  issues                Json
  engineSummary         String              @db.Text
  durationMinutes       Int
  targetDurationMinutes Int
  durationDeltaMinutes  Int
  createdByEmail        String
  createdAt             DateTime            @default(now())
  approvedAt            DateTime?
  publishedAt           DateTime?
  tour                  AdminTour           @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId, createdAt])
  @@index([status])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  actor     String
  action    String
  target    String
  details   Json
  createdAt DateTime @default(now())

  @@index([actor, createdAt])
}
