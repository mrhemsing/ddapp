generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntitlementSource {
  stripe
}

enum MagicLinkPurpose {
  activate
  signin
}

enum AdminStopStatus {
  live
  held
}

enum CityStatus {
  draft
  live
  archived
}

enum AdminTourStatus {
  draft
  published
  archived
}

enum OrderProposalStatus {
  draft
  approved
  rejected
  published
}

enum AudioSubjectType {
  stop
  leg
}

enum AudioAssetStatus {
  pending
  generating
  ready
  failed
}

model User {
  id                 String           @id @default(cuid())
  email              String           @unique
  marketingConsent   Boolean          @default(false)
  marketingConsentAt DateTime?
  createdAt          DateTime         @default(now())
  devices            Device[]
  entitlements       Entitlement[]
  magicLinks         MagicLinkToken[]
}

model Entitlement {
  id                    String            @id @default(cuid())
  userId                String
  packSlug              String
  source                EntitlementSource @default(stripe)
  stripeSessionId       String            @unique
  stripePaymentIntentId String?
  grantedAt             DateTime          @default(now())
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, packSlug])
  @@index([packSlug])
}

model Device {
  id               String   @id @default(cuid())
  userId           String
  deviceId         String
  label            String?
  sessionTokenHash String   @unique
  createdAt        DateTime @default(now())
  lastSeenAt       DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId, lastSeenAt])
}

model MagicLinkToken {
  id        String           @id @default(cuid())
  userId    String?
  email     String
  tokenHash String           @unique
  purpose   MagicLinkPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
}

model AdminStop {
  id              String          @id @default(cuid())
  cityId          String
  slug            String
  name            String
  address         String?
  lat             Float
  lng             Float
  narrationScript String          @db.Text
  scriptHash      String
  safetyWarning   String          @db.Text
  themeTags       String[]
  status          AdminStopStatus @default(held)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  city            City            @relation(fields: [cityId], references: [id], onDelete: Cascade)
  fromLegs        Leg[]           @relation("LegFromStop")
  toLegs          Leg[]           @relation("LegToStop")
  tourStops       TourStop[]

  @@unique([cityId, slug])
  @@index([cityId])
  @@index([status])
}

model AdminTour {
  id                    String          @id @default(cuid())
  cityId                String
  slug                  String
  title                 String
  targetDurationMinutes Int             @default(70)
  status                AdminTourStatus @default(draft)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  city                  City            @relation(fields: [cityId], references: [id], onDelete: Cascade)
  stops                 TourStop[]
  proposals             OrderProposal[]

  @@unique([cityId, slug])
  @@index([cityId])
  @@index([status])
}

model TourStop {
  id               String    @id @default(cuid())
  tourId           String
  stopId           String
  position         Int
  isStart          Boolean   @default(false)
  isFinale         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  stop             AdminStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  tour             AdminTour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, stopId])
  @@unique([tourId, position])
  @@index([stopId])
}

model City {
  id                   String        @id @default(cuid())
  slug                 String        @unique
  packSlug             String        @unique
  name                 String
  timezone             String
  mapCenterLat         Float
  mapCenterLng         Float
  defaultVoiceConfigId String?
  status               CityStatus    @default(draft)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  defaultVoiceConfig   VoiceConfig?  @relation("CityDefaultVoice", fields: [defaultVoiceConfigId], references: [id], onDelete: SetNull)
  stops                AdminStop[]
  tours                AdminTour[]
  legs                 Leg[]
  voiceConfigs         VoiceConfig[] @relation("CityVoiceConfigs")

  @@index([status])
}

model Leg {
  id         String    @id @default(cuid())
  cityId     String
  fromStopId String
  toStopId   String
  driveScript String   @db.Text
  scriptHash String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  city       City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  fromStop   AdminStop @relation("LegFromStop", fields: [fromStopId], references: [id], onDelete: Cascade)
  toStop     AdminStop @relation("LegToStop", fields: [toStopId], references: [id], onDelete: Cascade)

  @@unique([cityId, fromStopId, toStopId])
  @@index([fromStopId])
  @@index([toStopId])
}

model VoiceConfig {
  id         String   @id @default(cuid())
  cityId     String?
  label      String
  provider   String
  voiceId    String
  modelId    String
  settings   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  city       City?    @relation("CityVoiceConfigs", fields: [cityId], references: [id], onDelete: Cascade)
  defaultFor City[]   @relation("CityDefaultVoice")

  @@unique([cityId, label])
  @@index([cityId])
}

model AudioAsset {
  id                  String           @id @default(cuid())
  subjectType         AudioSubjectType
  subjectId           String
  contentHash         String
  voiceConfigSnapshot Json
  storagePath         String
  durationSeconds     Float
  fileBytes           Int
  status              AudioAssetStatus @default(pending)
  error               String?
  createdAt           DateTime         @default(now())

  @@unique([subjectType, subjectId, contentHash])
  @@index([subjectType, subjectId, status])
  @@index([contentHash])
}

model OrderProposal {
  id                    String              @id @default(cuid())
  tourId                String
  status                OrderProposalStatus @default(draft)
  trigger               String
  currentOrder          Json
  proposedOrder         Json
  placementReasons      Json
  invalidatedLegs       Json
  issues                Json
  engineSummary         String              @db.Text
  durationMinutes       Int
  targetDurationMinutes Int
  durationDeltaMinutes  Int
  createdByEmail        String
  createdAt             DateTime            @default(now())
  approvedAt            DateTime?
  publishedAt           DateTime?
  tour                  AdminTour           @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId, createdAt])
  @@index([status])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  actor     String
  action    String
  target    String
  details   Json
  createdAt DateTime @default(now())

  @@index([actor, createdAt])
}
